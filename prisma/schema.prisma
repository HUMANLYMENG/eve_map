// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WormholeRecord {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 星系信息
  fromSystemId   String
  fromSystemName String
  toSystemId     String
  toSystemName   String
  
  // 虫洞属性
  size        String?  // XL, L, M, S
  mass        String?  
  lifetime    Int      // 剩余分钟
  
  // 书签名（信号）
  fromSignal  String?
  toSignal    String?
  
  // 来源
  source      String   // "eve_scout" | "local" | "manual"
  createdBy   String?  // 创建者用户名
  
  // 过期时间
  expiresAt   DateTime
  isExpired   Boolean  @default(false)
  
  @@index([fromSystemId])
  @@index([toSystemId])
  @@index([expiresAt])
}

model PathRecord {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  
  userId      String
  userName    String
  
  // 路径数据 JSON
  systems     Json     // [{id, name, time}, ...]
  connections Json     // [{from, to, type}, ...]
  
  isShared    Boolean  @default(false)
  shareToken  String?  @unique
}
